<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="20dp"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#1C1C1E">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="listenForFeedbacks()" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- 3D Dönen Daire ve Dalga Konteynırı -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="16dp">

            <!-- Arka Plandaki Parlama Efekti -->
            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_ios_ambient_glow"
                android:backgroundTint="#FF9500"
                android:alpha="0.3"/>

            <!-- Dinamik Dalga Görseli (Buraya Custom View veya Lottie Gelebilir) -->
            <!-- Şimdilik görsel bir simülasyon için ProgressBar kullanıyoruz -->
            <ProgressBar
                android:id="@+id/audioWaveProgress"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:indeterminateDrawable="@drawable/custom_recording_wave" />

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="#FF9500" />
        </FrameLayout>

        <!-- Zaman Sayacı -->
        <TextView
            android:id="@+id/txtTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:fontFamily="sans-serif-thin"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ders Ses Kaydı Yapılıyor..."
            android:textColor="#8E8E93"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopRecording"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="Kaydı Durdur ve Analiz Et"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="18dp"
            android:backgroundTint="#FF3B30"
            app:icon="@android:drawable/ic_media_pause"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>