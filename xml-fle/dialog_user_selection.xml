<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/ios_card_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- dialog_user_selection.xml dosyanızdaki başlık TextView'ını şu şekilde güncelleyin -->
        <TextView
            android:id="@+id/txtDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hesap Türünü Seçin"
            android:textColor="@color/ios_text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectTeacher"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="@color/ios_blue"
            android:text="Eğitmen"
            android:textAllCaps="false"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_lesson_ios" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectStudent"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:text="Öğrenci"
            android:textAllCaps="false"
            android:textColor="@color/ios_blue"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_students_ios"
            app:strokeColor="@color/ios_blue" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>