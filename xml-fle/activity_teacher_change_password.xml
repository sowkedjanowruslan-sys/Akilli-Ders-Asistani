<?xml version="1.0" encoding="utf-8"?><!--
    APPLE IPHONE 17 PRO DESIGN SYSTEM
    MODULE: SECURITY & CRYPTOGRAPHY
    VIEW: TEACHER PASSWORD TRANSFORMATION
    DESIGNER NOTES: Hairline borders, soft #999 shadows, high-clarity typography.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBFBFD"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- LAYER 0: AMBIENT SECURITY GLOW (Arka Plan Güvenlik Işıltısı) -->
    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="generateAutoQuizFromPdf" />

    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:layout_marginTop="-250dp"
        android:alpha="0.3"
        android:background="@drawable/bg_ios_ambient_glow"
        android:backgroundTint="#F2F2F7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- TOP NAVIGATION: IOS MODAL STYLE -->
    <RelativeLayout
        android:id="@+id/topNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="20dp"
        android:background="#CCFBFBFD"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btnCancelPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Vazgeç"
            android:textColor="@color/ios_blue"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Şifre"
            android:textColor="#1D1D1F"
            android:textSize="17sp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/btnSavePassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Bitti"
            android:textColor="@color/ios_blue"
            android:textSize="17sp"
            android:alpha="0.5"
            android:fontFamily="sans-serif-black" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topNav"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- HERO ICON AREA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="32dp"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="1dp"
                    app:strokeColor="#0D000000"
                   >

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        app:tint="@color/ios_blue" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Kimlik Doğrulama"
                    android:textColor="#1D1D1F"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="24dp"
                    android:text="Hesap güvenliğiniz için şifrenizi düzenli aralıklarla güncelleyin."
                    android:textColor="#86868B"
                    android:textSize="14sp"
                    android:textAlignment="center"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- GROUPED INPUT SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp"
                android:text="GÜNCELLEME"
                android:textColor="#6E6E73"
                android:textSize="13sp"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-medium" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E5EA"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- CURRENT PASSWORD -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:id="@+id/lbOld"
                            android:layout_width="110dp"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Mevcut Şifre"
                            android:textColor="#1D1D1F"
                            android:textSize="17sp" />
                        <EditText
                            android:id="@+id/edtOldPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/lbOld"
                            android:background="@android:color/transparent"
                            android:hint="Gerekli"
                            android:inputType="textPassword"
                            android:textColorHint="#C7C7CC"
                            android:textSize="17sp"
                            android:gravity="end|center_vertical" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" android:layout_marginStart="16dp"/>

                    <!-- NEW PASSWORD -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:id="@+id/lbNew"
                            android:layout_width="110dp"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Yeni Şifre"
                            android:textColor="#1D1D1F"
                            android:textSize="17sp" />
                        <EditText
                            android:id="@+id/edtNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/lbNew"
                            android:background="@android:color/transparent"
                            android:hint="En az 8 Karakter"
                            android:inputType="textPassword"
                            android:textColorHint="#C7C7CC"
                            android:textSize="17sp"
                            android:gravity="end|center_vertical" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" android:layout_marginStart="16dp"/>

                    <!-- CONFIRM PASSWORD -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:id="@+id/lbConfirm"
                            android:layout_width="110dp"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Doğrula"
                            android:textColor="#1D1D1F"
                            android:textSize="17sp" />
                        <EditText
                            android:id="@+id/edtNewPasswordConfirm"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/lbConfirm"
                            android:background="@android:color/transparent"
                            android:hint="Tekrar Girin"
                            android:inputType="textPassword"
                            android:textColorHint="#C7C7CC"
                            android:textSize="17sp"
                            android:gravity="end|center_vertical" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PASSWORD STRENGTH INDICATOR (iPhone 17 Feature Simulation) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Şifre Gücü"
                    android:textColor="#86868B"
                    android:textSize="12sp" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/passwordStrengthProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:trackThickness="4dp"
                    app:trackCornerRadius="2dp"
                    android:progress="30"
                    app:indicatorColor="#FF3B30"
                    app:trackColor="#1AFF3B30" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="16dp"
                android:text="Şifreniz büyük harf, küçük harf, rakam ve özel karakter içermelidir. Başarıyla değiştirildiğinde tüm cihazlardan çıkış yapılacaktır."
                android:textColor="#86868B"
                android:textSize="13sp"
                android:fontFamily="sans-serif" />

            <!-- PREMIUM ACTION: BIOMETRIC TOGGLE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E5EA"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:id="@+id/icFaceId"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="@color/ios_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/icFaceId"
                        android:layout_marginStart="16dp"
                        android:text="Face ID ile Onayla"
                        android:textColor="#1D1D1F"
                        android:textSize="17sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true"
                        app:thumbTint="@android:color/white"
                        app:trackTint="@color/ios_blue" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>