<?xml version="1.0" encoding="utf-8"?>
<!--
    ULTRA PREMIUM IOS 17 REPEAT REQUEST DIALOG
    Design Strategy: Apple Attention / High Priority Yellow System
    Features: Bento Box Feedback, Floating Avatar, iOS Typography
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="24dp"
    app:cardCornerRadius="44dp"
    app:cardElevation="0dp"
    app:strokeWidth="2dp"
    app:strokeColor="#FF9500"
    android:backgroundTint="#FFFBF2">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- 1. KATMAN: IOS GRABBER (ÜST TUTAMAK) -->
        <View
            android:id="@+id/viewGrabber"
            android:layout_width="36dp"
            android:layout_height="5dp"
            android:layout_marginTop="12dp"
            android:background="#FF9500"
            android:alpha="0.2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 2. KATMAN: HEADER GRADIENT (DİNAMİK PARLAMA) -->
        <View
            android:id="@+id/warningHeader"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/bg_ios_gradient_blob"
            android:backgroundTint="#FF9500"
            android:alpha="0.12"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 3. KATMAN: AVATAR SİSTEMİ (PREMIUM BORDER) -->
        <FrameLayout
            android:id="@+id/avatarFrame"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="45dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Decorative Glow Aura -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_ios_round_button"
                android:backgroundTint="#FF9500"
                android:alpha="0.15" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                app:cardCornerRadius="55dp"
                app:cardElevation="12dp"
                app:strokeWidth="4dp"
                app:strokeColor="#FFFFFF">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgNotifAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera"
                    app:shapeAppearanceOverlay="@style/CircleImage" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Sync/Repeat Icon Badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                app:cardCornerRadius="19dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FF9500">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_popup_sync"
                    app:tint="#FFFFFF" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <!-- 4. KATMAN: İÇERİK ALANI (APPLE SAN FRANCISCO STYLE) -->
        <LinearLayout
            android:id="@+id/textContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/avatarFrame">

            <TextView
                android:id="@+id/lblRequestOwner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEKRAR TALEBİ"
                android:textColor="#FF9500"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.12" />

            <TextView
                android:id="@+id/txtNotifStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-black"
                android:text="Öğrenci Adı Soyadı"
                android:textColor="#1C1C1E"
                android:textSize="26sp"
                android:letterSpacing="-0.03" />

            <TextView
                android:id="@+id/txtNotifTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Bu Bölümü Tekrar Eder Misiniz?"
                android:textColor="#A05A00"
                android:textSize="19sp"
                android:fontFamily="sans-serif-bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Öğrenci konunun pekiştirilmesini istiyor."
                android:textColor="#8E8E93"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <!-- BENTO BOX: ÖĞRENCİ NOTU -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FFE0B2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MESAJ"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#FF9500"
                        android:alpha="0.7"/>

                    <TextView
                        android:id="@+id/txtNotifStudentNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Hocam bu son anlattığınız örneği kaçırdım, rica etsem üstünden bir daha geçebilir miyiz?"
                        android:textColor="#1C1C1E"
                        android:textSize="16sp"
                        android:lineSpacingExtra="5dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- 5. KATMAN: AKSİYON BUTONLARI -->
        <LinearLayout
            android:id="@+id/actionArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/textContainer">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotifOk"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Talebi İncele"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                android:backgroundTint="#FF9500"
                app:icon="@android:drawable/ic_menu_search"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:elevation="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:text="Gerçek zamanlı bildirim aktif."
                android:textColor="#8E8E93"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:alpha="0.6" />
        </LinearLayout>

        <!-- IOS HOME INDICATOR DECORATION -->
        <View
            android:layout_width="120dp"
            android:layout_height="5dp"
            android:layout_marginTop="20dp"
            android:background="#FF9500"
            android:alpha="0.1"
            app:layout_constraintTop_toBottomOf="@id/actionArea"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>