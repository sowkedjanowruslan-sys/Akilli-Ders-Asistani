<?xml version="1.0" encoding="utf-8"?>
<!--
    ULTRA PREMIUM IOS 17 NEW SESSION DIALOG
    Design Strategy: Apple Bento Grid / Rounded Action Sheet
    Hata Giderimi: Tüm ID referansları hiyerarşik olarak düzeltildi.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="24dp"
    app:cardCornerRadius="42dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="#E5E5EA"
    android:backgroundTint="#F2F2F7">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- 1. ÜST TUTAMAK (IOS GRABBER) -->
        <View
            android:id="@+id/viewGrabber"
            android:layout_width="36dp"
            android:layout_height="5dp"
            android:layout_marginTop="12dp"
            android:background="#D1D1D6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 2. HEADER BÖLÜMÜ -->
        <LinearLayout
            android:id="@+id/headerArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/viewGrabber"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:backgroundTint="#007AFF">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="#FFFFFF"
                    android:contentDescription="Session Icon" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/txtMainTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="Yeni Ders\nBaşlatın"
                android:textColor="#1C1C1E"
                android:textSize="34sp"
                android:letterSpacing="-0.03"
                android:lineSpacingExtra="-4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Oturum bilgilerini girerek başlayın."
                android:textColor="#8E8E93"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- 3. INPUT GRUBU (IPHONE BENTO LIST) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/formContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E5EA"
            android:backgroundTint="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/headerArea"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- KURUM / ÜNİVERSİTE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KURUM BİLGİSİ"
                        android:textColor="#8E8E93"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05" />
                    <EditText
                        android:id="@+id/edtUniversity"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@android:color/transparent"
                        android:hint="Üniversite veya Okul Adı"
                        android:inputType="textCapWords"
                        android:textColor="#1C1C1E"
                        android:textSize="16sp"
                        android:textColorHint="#C7C7CC" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F7" android:layout_marginHorizontal="16dp"/>

                <!-- BÖLÜM (İSTEDİĞİN YENİ ALAN) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BÖLÜM / PROGRAM"
                        android:textColor="#8E8E93"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05" />
                    <EditText
                        android:id="@+id/edtDepartment"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@android:color/transparent"
                        android:hint="Bölümünüzü Girin"
                        android:inputType="textCapWords"
                        android:textColor="#1C1C1E"
                        android:textSize="16sp"
                        android:textColorHint="#C7C7CC" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F7" android:layout_marginHorizontal="16dp"/>

                <!-- SINIF / LOKASYON -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SINIF / LOKASYON"
                        android:textColor="#8E8E93"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05" />
                    <EditText
                        android:id="@+id/edtClassRoom"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@android:color/transparent"
                        android:hint="Örn: Derslik 302"
                        android:inputType="textCapCharacters"
                        android:textColor="#1C1C1E"
                        android:textSize="16sp"
                        android:textColorHint="#C7C7CC" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F2F7" android:layout_marginHorizontal="16dp"/>

                <!-- DERS KONUSU (YENİ EKLEDİĞİMİZ ALAN) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DERS KONUSU / ÜNİTE"
                        android:textColor="#007AFF"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05" />
                    <EditText
                        android:id="@+id/edtLessonTopic"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@android:color/transparent"
                        android:hint="Örn: Newton Yasaları veya Türev"
                        android:inputType="textCapSentences"
                        android:textColor="#1C1C1E"
                        android:textSize="16sp"
                        android:textColorHint="#C7C7CC" />
                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 4. SESLİ BİLDİRİM AYARI (IOS SWITCH) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/settingsCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E5EA"
            android:backgroundTint="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/formContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/iconVoice"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="#34C759"
                    android:contentDescription="Voice Icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/iconVoice"
                    android:fontFamily="sans-serif-medium"
                    android:text="Sesli Bildirimler"
                    android:textColor="#1C1C1E"
                    android:textSize="15sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchVoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:checked="true" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 5. AKSİYON BUTONLARI -->
        <LinearLayout
            android:id="@+id/buttonArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/settingsCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartLessonCustom"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Dersi Başlat"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:cornerRadius="20dp"
                android:backgroundTint="#007AFF"
                app:elevation="4dp"
                app:icon="@android:drawable/ic_media_play"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelCustom"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Vazgeç"
                android:textAllCaps="false"
                android:textColor="#007AFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- 6. ALT BİLGİ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="PRO CONNECT SECURE ACCESS"
            android:textColor="#C7C7CC"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.2"
            app:layout_constraintTop_toBottomOf="@id/buttonArea"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>