<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="8dp">

    <View
        android:id="@+id/viewAmbientGlow"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/bg_ios_ambient_glow"
        android:backgroundTint="#6200EE"
        android:alpha="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-100dp"
        android:layout_marginStart="-100dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardQuizMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="38dp"
        app:cardElevation="12dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#F2F2F7"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white">

            <!-- ÜST PANEL: İSTATİSTİK VE PROGRESS -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:background="#FBFBFF">

                <!-- Soru Sayacı (Sol) -->
                <LinearLayout
                    android:id="@+id/layoutProgressInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/txtQuizProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soru 01"
                        android:textColor="#1C1C1E"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toplam 5 Soru"
                        android:textColor="#8E8E93"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Skor Rozeti (Sağ) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#F3E5F5"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/layoutProgressInfo"
                    app:layout_constraintBottom_toBottomOf="@id/layoutProgressInfo">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/btn_star_big_on"
                            app:tint="#6200EE" />

                        <TextView
                            android:id="@+id/txtQuizScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Skor: 0"
                            android:textColor="#6200EE"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Premium Progress Bar -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/quizProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:indicatorColor="#6200EE"
                    app:trackColor="#F2F2F7"
                    app:trackCornerRadius="8dp"
                    app:layout_constraintTop_toBottomOf="@id/layoutProgressInfo"
                    android:progress="20" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- SORU KARTI (Floating Effect) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F2F2F7"
                app:cardBackgroundColor="#FFFFFF">

                <TextView
                    android:id="@+id/txtQuestionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:text="Yapay zeka analizine göre bu dersin en kritik noktası hangisidir?"
                    android:textColor="#1C1C1E"
                    android:textSize="19sp"
                    android:lineSpacingExtra="6dp"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:minHeight="120dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ŞIKLAR ALANI (Modern Selection List) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Seçenek A -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOptA"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:text="A) Seçenek İçeriği Buraya Gelecek"
                    android:textAlignment="viewStart"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="#48484A"
                    app:cornerRadius="20dp"
                    app:strokeColor="#E5E5EA"
                    app:strokeWidth="1.5dp"
                    app:rippleColor="#1A6200EE"
                    android:fontFamily="sans-serif-medium" />

                <!-- Seçenek B -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOptB"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginTop="10dp"
                    android:text="B) Alternatif Cevap Seçeneği"
                    android:textAlignment="viewStart"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="#48484A"
                    app:cornerRadius="20dp"
                    app:strokeColor="#E5E5EA"
                    app:strokeWidth="1.5dp"
                    app:rippleColor="#1A6200EE"
                    android:fontFamily="sans-serif-medium" />

                <!-- Seçenek C -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOptC"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginTop="10dp"
                    android:text="C) Bilgi Odaklı Çözüm Şıkkı"
                    android:textAlignment="viewStart"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="#48484A"
                    app:cornerRadius="20dp"
                    app:strokeColor="#E5E5EA"
                    app:strokeWidth="1.5dp"
                    app:rippleColor="#1A6200EE"
                    android:fontFamily="sans-serif-medium" />

                <!-- Seçenek D -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOptD"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginTop="10dp"
                    android:text="D) Analitik Yaklaşım Şıkkı"
                    android:textAlignment="viewStart"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="#48484A"
                    app:cornerRadius="20dp"
                    app:strokeColor="#E5E5EA"
                    app:strokeWidth="1.5dp"
                    app:rippleColor="#1A6200EE"
                    android:fontFamily="sans-serif-medium" />

                <!-- SONUÇ GÖNDERME BUTONU (Sadece bitince görünür) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="20dp"
                    android:text="Sonuçları Hocaya İlet"
                    android:visibility="gone"
                    android:backgroundTint="#34C759"
                    android:textColor="@android:color/white"
                    android:fontFamily="sans-serif-black"
                    app:cornerRadius="22dp"
                    app:icon="@android:drawable/ic_menu_send"
                    app:iconTint="@android:color/white"
                    app:elevation="6dp" />

            </LinearLayout>

            <!-- FOOTER: FEEDBACK AREA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Canlı Sınav Oturumu"
                    android:textSize="10sp"
                    android:textColor="#D1D1D6"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- EKSTRA: YÜZER SÜSLEMELER (Animasyon için) -->
    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_ai_sparkles"
        app:tint="#6200EE"
        android:alpha="0.2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardQuizMain"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>