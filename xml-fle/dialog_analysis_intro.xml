<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    android:layout_margin="16dp"
    app:cardElevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#5856D6"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gelişmiş Konu ve Verim Analizi"
            android:textSize="20sp"
            android:textAlignment="center"
            android:fontFamily="sans-serif-black"
            android:textColor="#1C1C1E"/>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="16dp"
            android:fadeScrollbars="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍 Bu Modül Nedir?"
                    android:textStyle="bold"
                    android:textColor="#5856D6"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ders sonunda aldığınız raporları veya dökümanları tarayarak, sınıfın genel başarı grafiğini ve öğrenme engellerini tespit eden bir yapay zeka asistanıdır."
                    android:textSize="13sp"
                    android:textColor="#48484A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️ Nasıl Kullanılır?"
                    android:textStyle="bold"
                    android:textColor="#5856D6"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. PDF Yükle: Daha önce kaydettiğiniz ders dökümünü veya öğrenci geri bildirim PDF'ini seçin.\n2. AI Analizi: Gemini 2.5 Flash metni saniyeler içinde tarar.\n3. Raporu İncele: Hangi konuların tam anlaşıldığını, hangilerinin tekrar edilmesi gerektiğini görün."
                    android:textSize="13sp"
                    android:textColor="#48484A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Size Sağladığı Faydalar"
                    android:textStyle="bold"
                    android:textColor="#5856D6"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Kritik Durum Analizi: Sınıfın en çok zorlandığı 'dar boğaz' noktalarını anında belirler.\n• Gelecek Hafta Planı: AI, analiz sonuçlarına dayanarak bir sonraki dersiniz için size özel bir öğretim planı önerir.\n• Zaman Yönetimi: Binlerce satır ders notunu manuel okumak yerine, tek bir özet panelinden her şeye hakim olursunuz."
                    android:textSize="13sp"
                    android:textColor="#48484A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚀 Akademik Verimlilik"
                    android:textStyle="bold"
                    android:textColor="#5856D6"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Veriye dayalı eğitim modeline geçerek öğrencilerinizin gelişimini profesyonel şekilde takip edin."
                    android:textSize="13sp"
                    android:textColor="#48484A"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalysisIntroStart"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:text="Analiz Sistemini Başlat"
            app:cornerRadius="18dp"
            android:backgroundTint="#5856D6"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-bold"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>