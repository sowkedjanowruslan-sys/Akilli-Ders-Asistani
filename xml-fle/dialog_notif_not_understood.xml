<?xml version="1.0" encoding="utf-8"?>
<!--
    ULTRA PREMIUM IOS 17 CRITICAL ALERT DIALOG
    Design: Apple Critical Notification System
    Logic: High-Contrast Alert / Glassmorphism / Immersion
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="24dp"
    app:cardCornerRadius="44dp"
    app:cardElevation="0dp"
    app:strokeWidth="2dp"
    app:strokeColor="#FF3B30"
    android:backgroundTint="#FFF5F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- 1. KATMAN: ÜST TUTAMAK (IOS GRABBER) -->
        <View
            android:id="@+id/viewGrabber"
            android:layout_width="36dp"
            android:layout_height="5dp"
            android:layout_marginTop="12dp"
            android:background="#FF3B30"
            android:alpha="0.2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 2. KATMAN: KRİTİK HEADER GRADIENT -->
        <View
            android:id="@+id/dangerHeader"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="@drawable/bg_ios_gradient_blob"
            android:backgroundTint="#FF3B30"
            android:alpha="0.1"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 3. KATMAN: EMOJI BADGE (DYNAMIC ISLAND STYLE) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEmoji"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#FF3B30"
            android:backgroundTint="#FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="❓"
                android:textSize="26sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. KATMAN: AVATAR SİSTEMİ (PRO BORDER) -->
        <FrameLayout
            android:id="@+id/avatarFrame"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="50dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Pulse Animation Aura -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_ios_round_button"
                android:backgroundTint="#FF3B30"
                android:alpha="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                app:cardCornerRadius="60dp"
                app:cardElevation="10dp"
                app:strokeWidth="4dp"
                app:strokeColor="#FFFFFF">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgNotifAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera"
                    app:shapeAppearanceOverlay="@style/CircleImage" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Status Indicator -->
            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="14dp"
                android:background="@drawable/bg_status_online"
                android:backgroundTint="#FF3B30" />
        </FrameLayout>

        <!-- 5. KATMAN: İÇERİK ALANI (APPLE TYPOGRAPHY) -->
        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/avatarFrame">

            <TextView
                android:id="@+id/lblStudentId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ÖĞRENCİ KİMLİĞİ"
                android:textColor="#FF3B30"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/txtNotifStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-black"
                android:text="Öğrenci Adı Soyadı"
                android:textColor="#1C1C1E"
                android:textSize="26sp"
                android:letterSpacing="-0.03" />

            <TextView
                android:id="@+id/txtNotifTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Konu Anlaşılamadı"
                android:textColor="#FF3B30"
                android:textSize="20sp"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Öğrenci bu bölümde yardıma ihtiyaç duyuyor."
                android:textColor="#8E8E93"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <!-- FEEDBACK BENTO BOX -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FFCDD2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ÖĞRENCİ NOTU"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#FF3B30"
                        android:alpha="0.6"/>

                    <TextView
                        android:id="@+id/txtNotifStudentNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Hocam bu kısmı tam olarak kavrayamadım, tekrar edebilir miyiz?"
                        android:textColor="#1C1C1E"
                        android:textSize="16sp"
                        android:lineSpacingExtra="6dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- 6. KATMAN: AKSİYON BUTONLARI -->
        <LinearLayout
            android:id="@+id/actionArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/contentContainer">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotifOk"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Anladım"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                android:backgroundTint="#FF3B30"
                app:icon="@android:drawable/ic_menu_search"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:alpha="0.5"
                android:fontFamily="sans-serif-bold"
                android:text="Bu bildirim kritiktir."
                android:textColor="#FF3B30"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- IOS HOME INDICATOR -->
        <View
            android:layout_width="120dp"
            android:layout_height="5dp"
            android:layout_marginTop="20dp"
            android:background="#FF3B30"
            android:alpha="0.1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/actionArea"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>