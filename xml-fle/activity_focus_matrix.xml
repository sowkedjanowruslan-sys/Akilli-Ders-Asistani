<?xml version="1.0" encoding="utf-8"?>
<!--
    =========================================================================================
    PROJECT: AKILLI DERS ASISTANI - FOCUS MATRIX PRO
    VERSION: V7.0 MASTER ARCHITECT [ULTRA PREMIUM EDITION]
    DESIGN ARCHITECT: APPLE iOS 18 DYNAMIC GLASS SYSTEM
    DEVELOPER NOTE: Bu dosya 550+ satır profesyonel UI mimarisi içerir.
    =========================================================================================
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/focusRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBFBFD"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".FocusMatrixActivity">

    <!--
        =========================================================================================
        LAYER 0: AMBIENT INTELLIGENCE LIGHTING SYSTEM
        iOS 18 tarzı dinamik arka plan ışıkları.
        =========================================================================================
    -->
    <FrameLayout
        android:id="@+id/ambientLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no">

        <!-- Mor Safir Işıltı (Üst Sağ) -->
        <View
            android:id="@+id/glowPurple"
            android:layout_width="650dp"
            android:layout_height="650dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-300dp"
            android:layout_marginEnd="-220dp"
            android:alpha="0.22"
            android:background="@drawable/bg_ios_ambient_glow"
            android:backgroundTint="#5856D6" />

        <!-- Mavi Okyanus Işıltı (Orta Sol) -->
        <View
            android:id="@+id/glowBlue"
            android:layout_width="500dp"
            android:layout_height="500dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="-250dp"
            android:alpha="0.15"
            android:background="@drawable/bg_ios_ambient_glow"
            android:backgroundTint="#007AFF" />

        <!-- Zümrüt Yeşili Işıltı (Alt Sağ) -->
        <View
            android:id="@+id/glowEmerald"
            android:layout_width="550dp"
            android:layout_height="550dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="-250dp"
            android:layout_marginEnd="-150dp"
            android:alpha="0.12"
            android:background="@drawable/bg_ios_ambient_glow"
            android:backgroundTint="#34C759" />
    </FrameLayout>

    <!--
        =========================================================================================
        LAYER 1: NAVIGATION & BENTO STATISTICS BAR
        İstatistikleri şık cam kutucuklarda (Bento Grid) sunan üst panel.
        =========================================================================================
    -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/focusAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/focusToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStart="0dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp">
                <ImageButton
                    android:id="@+id/btnBackFromFocus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="#1C1C1E" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="NEURAL FOCUS"
                    android:textColor="#1C1C1E"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"/>
            </RelativeLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Bento Stats Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/topStatsCard"
            android:layout_width="match_parent"
            android:layout_height="125dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="42dp"
            app:cardElevation="16dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#1A000000"
            app:cardBackgroundColor="#CCFFFFFF">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="24dp">

                <!-- [BENTO 1: LEVEL INFO] -->
                <LinearLayout
                    android:id="@+id/levelSection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <TextView
                        android:id="@+id/txtLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LEVEL 01"
                        android:textColor="#8E8E93"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.12" />
                    <TextView
                        android:id="@+id/txtTileCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3x3 Grid"
                        android:textColor="#1C1C1E"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="-2dp"/>
                </LinearLayout>

                <!-- [BENTO 2: CENTRAL TIMER] -->
                <RelativeLayout
                    android:id="@+id/timerWrapper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@id/levelSection"
                    app:layout_constraintEnd_toStartOf="@id/wrongSection"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/timerProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:progress="100"
                        app:indicatorSize="84dp"
                        app:trackThickness="9dp"
                        app:indicatorColor="#5856D6"
                        app:trackColor="#F2F2F7"
                        app:trackCornerRadius="12dp"/>

                    <TextView
                        android:id="@+id/txtTimerSeconds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="20"
                        android:textColor="#5856D6"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"/>
                </RelativeLayout>

                <!-- [BENTO 3: ERRORS] -->
                <LinearLayout
                    android:id="@+id/wrongSection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ERRORS"
                        android:textColor="#FF3B30"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.12" />
                    <TextView
                        android:id="@+id/txtWrongCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FF3B30"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="-4dp"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </com.google.android.material.appbar.AppBarLayout>

    <!--
        =========================================================================================
        LAYER 2: THE INTERACTIVE FOCUS ARENA
        İç gölgeli, derinlikli ana matris alanı.
        =========================================================================================
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/gridContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="56dp"
        app:cardElevation="32dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#0D000000"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/focusAppBar"
        app:layout_constraintBottom_toTopOf="@id/performanceDisplay">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_ios_input_field">

            <GridLayout
                android:id="@+id/matrixGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="32dp"
                android:rowCount="3"
                android:columnCount="3"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!--
        =========================================================================================
        LAYER 3: REAL-TIME PERFORMANCE INDICATOR
        =========================================================================================
    -->
    <LinearLayout
        android:id="@+id/performanceDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/guidanceCard">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CURRENT STREAK"
            android:textColor="#8E8E93"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.12"/>

        <TextView
            android:id="@+id/txtRoundInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#1C1C1E"
            android:textSize="54sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.05"/>
    </LinearLayout>

    <!--
        =========================================================================================
        LAYER 4: GUIDANCE ENGINE
        Apple tarzı akıllı bilgilendirme şeridi.
        =========================================================================================
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/guidanceCard"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="4dp"
        app:strokeWidth="1dp"
        app:strokeColor="#1A5856D6"
        app:cardBackgroundColor="#0D5856D6"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/txtInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEMORIZE THE PATTERN"
                android:textColor="#5856D6"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="#5856D6"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>