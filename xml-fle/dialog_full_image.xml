<?xml version="1.0" encoding="utf-8"?>
<!--
    ULTRA PREMIUM IOS 17 FULL IMAGE VIEW
    Design: Apple Photos / Vision OS Immersion Style
    Features: Floating Glass Controls, Dynamic Backdrop, High Precision Typography
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 1. KATMAN: DİNAMİK ARKA PLAN (Görselin kendisinden üretilen derinlik) -->
    <ImageView
        android:id="@+id/imgFullBlur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.4"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        tools:src="@tools:sample/avatars" />

    <!-- 2. KATMAN: KARARTMA GRADIENT (Görselin üzerine odaklanmak için) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_ios_photo_overlay" />

    <!-- 3. KATMAN: ANA GÖRSEL (Yüzen Panel Efekti) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgFull"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:adjustViewBounds="true"
        android:elevation="20dp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/RoundedImage"
        tools:src="@tools:sample/avatars" />

    <!-- 4. KATMAN: ÜST YÜZEN KONTROL BARI (Apple Style) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="44dp"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Kapatma Butonu (Glassmorphism Circular) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseFull"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:backgroundTint="#33FFFFFF"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="22dp"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="22dp"
            app:iconTint="#FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="#1AFFFFFF"
            app:strokeWidth="1dp" />

        <!-- Görsel Başlığı (Apple San Francisco Style) -->
        <!-- Görsel Başlığı (Apple San Francisco Style) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/txtFullTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:text="Profil Fotoğrafı"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/txtFullSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Eğitmen Görünümü"
                android:textColor="#B0B0B0"
                android:textSize="12sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 5. KATMAN: ALT AKSİYON PANELİ (Yüzen Dock Efekti) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomActionDock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        app:cardBackgroundColor="#26FFFFFF"
        app:cardCornerRadius="30dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#1AFFFFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp">

            <!-- Paylaş Butonu -->
            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_share"
                app:tint="#FFFFFF" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="16dp"
                android:background="#33FFFFFF" />

            <!-- İndir Butonu -->
            <ImageButton
                android:id="@+id/btnSave"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/stat_sys_download"
                app:tint="#FFFFFF" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="16dp"
                android:background="#33FFFFFF" />

            <!-- Bilgi Butonu -->
            <ImageButton
                android:id="@+id/btnInfo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="#FFFFFF" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 6. KATMAN: HOME INDICATOR SİMÜLASYONU (Tam Premium His İçin) -->
    <View
        android:layout_width="140dp"
        android:layout_height="5dp"
        android:layout_marginBottom="8dp"
        android:background="#4DFFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:alpha="0.5" />
</androidx.constraintlayout.widget.ConstraintLayout>
