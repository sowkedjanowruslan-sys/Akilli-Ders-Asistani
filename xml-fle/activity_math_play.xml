<?xml version="1.0" encoding="utf-8"?>
<!--
    =========================================================================================
    PROJECT: AKILLI DERS ASISTANI - MATH WORLD PRO    VERSION: V7.0 MASTER ARCHITECT [ULTRA PREMIUM]
    DESIGN SYSTEM: APPLE iOS 18 DYNAMIC GLASS & BENTO GRID
    DEVELOPER NOTE: Bu dosya 550 satır profesyonel UI mimarisi içerir.
    =========================================================================================
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBFBFD"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".MathPlayActivity">

    <!--
        LAYER 0: AMBIENT INTELLIGENCE LIGHTING SYSTEM
        iOS 18 tarzı dinamik arka plan ışıkları.
    -->
    <FrameLayout
        android:id="@+id/ambientLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no">

        <!-- Mor Safir Işıltı (Üst Sağ) -->
        <View
            android:id="@+id/glowPurple"
            android:layout_width="650dp"
            android:layout_height="650dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-320dp"
            android:layout_marginEnd="-220dp"
            android:alpha="0.20"
            android:background="@drawable/bg_ios_ambient_glow"
            android:backgroundTint="#5856D6" />

        <!-- Mavi Okyanus Işıltı (Orta Sol) -->
        <View
            android:id="@+id/glowBlue"
            android:layout_width="500dp"
            android:layout_height="500dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="-250dp"
            android:alpha="0.15"
            android:background="@drawable/bg_ios_ambient_glow"
            android:backgroundTint="#007AFF" />

        <!-- Zümrüt Yeşili Işıltı (Alt Sağ) -->
        <View
            android:id="@+id/glowEmerald"
            android:layout_width="550dp"
            android:layout_height="550dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="-250dp"
            android:layout_marginEnd="-150dp"
            android:alpha="0.12"
            android:background="@drawable/bg_ios_ambient_glow"
            android:backgroundTint="#34C759" />

        <!-- Dekoratif Işık: Altın Dokunuş (Üst Sol) -->
        <View
            android:id="@+id/glowGold"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="-100dp"
            android:layout_marginStart="-100dp"
            android:alpha="0.08"
            android:background="@drawable/bg_ios_ambient_glow"
            android:backgroundTint="#FFD60A" />
    </FrameLayout>

    <!--
        LAYER 1: TOP NAVIGATION & BENTO STATISTICS
        Verileri şık bölmelerde sunan ana istatistik paneli.
    -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/topStatsCard"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="16dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#1A000000"
            app:cardBackgroundColor="#CCFFFFFF">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="24dp">

                <!-- [BENTO 1: PROGRESS] -->
                <LinearLayout
                    android:id="@+id/levelSection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:contentDescription="Seviye Bilgisi">

                    <TextView
                        android:id="@+id/txtLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LEVEL 01"
                        android:textColor="#8E8E93"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:id="@+id/txtQuestionCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01/20"
                        android:textColor="#1C1C1E"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="-4dp"/>
                </LinearLayout>

                <!-- [BENTO 2: DYNAMIC CLOCK] -->
                <RelativeLayout
                    android:id="@+id/timerWrapper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@id/levelSection"
                    app:layout_constraintEnd_toStartOf="@id/wrongSection"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/timerProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:progress="100"
                        app:indicatorSize="84dp"
                        app:trackThickness="9dp"
                        app:indicatorColor="#007AFF"
                        app:trackColor="#F2F2F7"
                        app:trackCornerRadius="12dp"/>

                    <TextView
                        android:id="@+id/txtTimerSeconds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="20"
                        android:textColor="#007AFF"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"/>
                </RelativeLayout>

                <!-- [BENTO 3: ERROR COUNTER] -->
                <LinearLayout
                    android:id="@+id/wrongSection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:contentDescription="Hata Sayısı">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ERRORS"
                        android:textColor="#FF3B30"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:id="@+id/txtWrongCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FF3B30"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="-4dp"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </com.google.android.material.appbar.AppBarLayout>

    <!--
        LAYER 2: MASTER QUESTION ARENA
        Hem matematiksel ifadeleri hem de sözel bilmeceleri mükemmel gösteren alan.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardQuestion"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="56dp"
        app:cardElevation="32dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#0D000000"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toTopOf="@id/scoreContainer">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_ios_input_field">

            <!-- Arka Plan Dekoratif Dokusu -->
            <ImageView
                android:id="@+id/decorationMath"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:src="@android:drawable/ic_menu_edit"
                android:alpha="0.04"
                android:rotation="-20"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="-50dp"
                android:layout_marginEnd="-50dp"
                android:importantForAccessibility="no" />

            <!-- ANA SORU METNİ: Dinamik boyutlandırmalı -->
            <TextView
                android:id="@+id/txtMathExpression"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingHorizontal="36dp"
                android:paddingVertical="40dp"
                android:text="-(-9+7-(+7))"
                android:textColor="#1C1C1E"
                android:textSize="38sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.03"
                android:lineSpacingMultiplier="1.1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="18sp"
                app:autoSizeMaxTextSize="44sp"
                app:autoSizeStepGranularity="2sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/txtInteractionTip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHOOSE WISELY"
                android:textColor="#C7C7CC"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="32dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!--
        LAYER 3: TOTAL POINTS DASHBOARD
        Skoru premium bir şekilde sergiler.
    -->
    <LinearLayout
        android:id="@+id/scoreContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/gridOptions">

        <TextView
            android:id="@+id/lblTotalPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SESSION PERFORMANCE"
            android:textColor="#8E8E93"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.12"/>

        <TextView
            android:id="@+id/txtMainScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#1C1C1E"
            android:textSize="56sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.06"/>
    </LinearLayout>

    <!--
        LAYER 4: RESPONSE ENGINE GRID
        Cevap butonlarını cam efektli ve yüksek etkileşimli sunar.
    -->
    <GridLayout
        android:id="@+id/gridOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:padding="12dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Buton 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="110dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            android:backgroundTint="#FFFFFF"
            android:text="\?"
            android:textColor="#1C1C1E"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="34dp"
            app:strokeWidth="2.5dp"
            app:strokeColor="#E5E5EA"
            app:elevation="8dp"
            android:stateListAnimator="@null"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <!-- Buton 2 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="110dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            android:backgroundTint="#FFFFFF"
            android:text="\?"
            android:textColor="#1C1C1E"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="34dp"
            app:strokeWidth="2.5dp"
            app:strokeColor="#E5E5EA"
            app:elevation="8dp"
            android:stateListAnimator="@null"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <!-- Buton 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_height="110dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            android:backgroundTint="#FFFFFF"
            android:text="\?"
            android:textColor="#1C1C1E"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="34dp"
            app:strokeWidth="2.5dp"
            app:strokeColor="#E5E5EA"
            app:elevation="8dp"
            android:stateListAnimator="@null"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <!-- Buton 4 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="110dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            android:backgroundTint="#FFFFFF"
            android:text="\?"
            android:textColor="#1C1C1E"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="34dp"
            app:strokeWidth="2.5dp"
            app:strokeColor="#E5E5EA"
            app:elevation="8dp"
            android:stateListAnimator="@null"
            style="@style/Widget.Material3.Button.TonalButton"/>
    </GridLayout>

    <!--
        EXTRA LAYER: DECORATIVE BOTTOM BLUR INDICATION
        Sayfanın en altına şık bir tasarım imzası.
    -->
    <View
        android:id="@+id/bottomSignature"
        android:layout_width="60dp"
        android:layout_height="5dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_ios_timer_track"
        android:backgroundTint="#E5E5EA"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>