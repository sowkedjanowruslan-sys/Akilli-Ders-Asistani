<?xml version="1.0" encoding="utf-8"?>
<!--
    APPLE DESIGN SYSTEM: LANGUAGE SELECTOR
    Blur-Glass Effect Simulation
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#F2F2F7"
    android:layout_margin="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- iOS Handle (Tepedeki çizgi) -->
        <View
            android:layout_width="36dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:background="#C7C7CC"
            android:layout_marginBottom="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dil / Language"
            android:textColor="#1C1C1E"
            android:textSize="17sp"
            android:fontFamily="sans-serif-black"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- SEÇENEKLER KUTUSU (iOS List Style) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0.5dp"
            app:strokeColor="#E5E5EA">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- TÜRKÇE SEÇENEĞİ -->
                <RelativeLayout
                    android:id="@+id/btnLangTr"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="20dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Türkçe"
                        android:textColor="#1C1C1E"
                        android:textSize="17sp" />

                    <ImageView
                        android:id="@+id/imgCheckTr"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="#007AFF"
                        android:visibility="gone" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#E5E5EA"
                    android:layout_marginStart="20dp" />

                <!-- ENGLISH SEÇENEĞİ -->
                <RelativeLayout
                    android:id="@+id/btnLangEn"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="20dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="English"
                        android:textColor="#1C1C1E"
                        android:textSize="17sp" />

                    <ImageView
                        android:id="@+id/imgCheckEn"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="#007AFF"
                        android:visibility="gone" />
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Vazgeç Butonu -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelLang"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Vazgeç"
            android:textColor="#007AFF"
            android:textSize="17sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>