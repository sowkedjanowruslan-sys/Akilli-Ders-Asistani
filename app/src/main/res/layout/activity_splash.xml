<?xml version="1.0" encoding="utf-8"?>
<!--
    APPLE PREMIUM LIGHT DESIGN SYSTEM - NEUTRAL STUDIO EDITION
    Version: 5.0 Platinum Refined
    Theme: Silver, Clarity & Precision + Cinematic Animations

    Z-INDEX STRATEGY:
    0-10: Mesh Gradient & Ambient Orbs
    10-20: Soft Shadow Backlights (Özel #999 gölge simülasyonu)
    20-30: Main Branding Elements (Logo & Text)
    30-40: Interactive Elements (Progress & Badges)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_bg_white"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".SplashActivity">

    <!-- ==========================================================
         LAYER 0: AMBIENT ENVIRONMENT (Arka Plan Işıkları)
         ========================================================== -->

    <View
        android:id="@+id/ambientOrb1"
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:layout_marginStart="-200dp"
        android:layout_marginTop="-200dp"
        android:alpha="0.4"
        android:background="@drawable/bg_ios_ambient_glow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/ambientOrb2"
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_marginEnd="-250dp"
        android:layout_marginBottom="-250dp"
        android:alpha="0.3"
        android:background="@drawable/bg_ios_ambient_glow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ==========================================================
         LAYER 1: CENTRAL BRANDING (Logo ve Metin Bölümü)
         ========================================================== -->

    <LinearLayout
        android:id="@+id/brandingWrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.44">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- #999 Gümüşi Derinlik Gölgesi -->
            <View
                android:layout_width="135dp"
                android:layout_height="135dp"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:alpha="0.3"
                android:background="@drawable/bg_ios_ambient_glow"
                android:backgroundTint="#999999" />

            <!-- LOGO KARTI -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/logoSurface"
                android:layout_width="145dp"
                android:layout_height="145dp"
                android:translationZ="15dp"
                app:cardCornerRadius="44dp"
                app:cardElevation="30dp"
                app:cardBackgroundColor="@color/ios_card_pure"
                app:strokeWidth="1dp"
                app:strokeColor="#999999">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_ios_logo_inner_gradient"
                        android:alpha="0.5" />

                    <ImageView
                        android:id="@+id/imgLogo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="38dp"
                        android:scaleType="fitCenter"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/ios_blue" />

                    <!-- Online/AI Indicator -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="26dp"
                        android:layout_marginEnd="26dp"
                        app:cardBackgroundColor="@color/ios_green"
                        app:cardCornerRadius="7dp"
                        app:cardElevation="8dp"
                        app:strokeWidth="1.5dp"
                        app:strokeColor="@color/ios_card_pure" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="45dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.3"
            android:text="@string/splash_smart_prefix"
            android:textColor="@color/ios_blue"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.04"
            android:text="@string/app_name_main"
            android:textColor="@color/ios_text_title"
            android:textSize="40sp"
            android:textAlignment="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:alpha="0.7"
            android:fontFamily="sans-serif-medium"
            android:text="@string/splash_tagline"
            android:textColor="@color/ios_text_body"
            android:textSize="15sp"
            android:textAlignment="center" />

        <!-- PREMIUM BADGE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:translationZ="20dp"
            app:cardBackgroundColor="@color/ios_blue"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="22dp"
                android:paddingVertical="10dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/badge_platinum"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ==========================================================
         LAYER 2: CINEMATIC PROGRESS AREA (Yükleme Paneli)
         Bu bölüm animasyonla (progress_entrance) gelecek
         ========================================================== -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/progressArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Progress Glow (Parlayan Alt Işık) -->
        <View
            android:layout_width="160dp"
            android:layout_height="20dp"
            android:alpha="0.3"
            android:background="@drawable/bg_ios_ambient_glow"
            android:backgroundTint="@color/ios_blue"
            app:layout_constraintBottom_toBottomOf="@id/progressWrapper"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/progressWrapper" />

        <FrameLayout
            android:id="@+id/progressWrapper"
            android:layout_width="200dp"
            android:layout_height="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Progress Kanalı -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="#0D000000"
                app:cardCornerRadius="2dp"
                app:cardElevation="0dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="#1A000000" />

            <!-- PLATINUM PROGRESS BAR (bg_ios_platinum_progress) -->
            <View
                android:id="@+id/splashProgressBar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_ios_platinum_progress" />
        </FrameLayout>

        <!-- Dinamik Durum Metni (status_breathing animasyonu için) -->
        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:alpha="0.5"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:text="SİSTEMLER KALİBRE EDİLİYOR"
            android:textColor="@color/ios_text_title"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressWrapper" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:alpha="0.2"
            android:fontFamily="sans-serif-medium"
            android:text="@string/footer_standards"
            android:textColor="@color/ios_text_title"
            android:textSize="9sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressWrapper" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>