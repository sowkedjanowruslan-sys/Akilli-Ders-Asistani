<?xml version="1.0" encoding="utf-8"?><androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7">

    <!-- ARKA PLAN EFEKTLERİ (Parlamalar ve Glow) -->
    <include layout="@layout/ambient_background_layers" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- HEADER BLUR & GRADIENT -->
        <View
            android:id="@+id/headerBlur"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:background="@drawable/hero_gradient"
            android:alpha="0.9"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- SIRALAMA YILDIZI (Leaderboard - Cam Efekti) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnShowRankings"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="20dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="#40FFFFFF"
            android:backgroundTint="#30FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="#FFD60A" />
        </com.google.android.material.card.MaterialCardView>

        <!-- ANA HOLOGRAFİK KART -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/previewCard"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginTop="90dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="32dp"
            app:strokeWidth="2dp"
            app:strokeColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/menu_header_gradient"
                android:alpha="0.05"/>

            <ImageView
                android:id="@+id/imgCentralIcon"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_sync_ios"
                android:padding="10dp"
                app:tint="#4F46E5" />

            <!-- Alt kısımdaki parlayan çizgi -->
            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_ios_round_button"
                android:backgroundTint="#4F46E5"
                android:alpha="0.3"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- İÇERİK PANELİ -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/previewCard"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp">

                <TextView
                    android:id="@+id/txtCurrentUnlockedLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LEVEL 01 UNLOCKED"
                    android:textColor="#4F46E5"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Neural Calibration"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#0F172A"
                    android:letterSpacing="-0.02"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ders akışı başlamadan önce işlemci hızınızı senkronize edin."
                    android:textColor="#64748B"
                    android:textSize="15sp"
                    android:lineHeight="22sp"
                    android:layout_marginTop="8dp"/>

                <!-- SLIDER CONTAINER (Bento Box Style) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Processing Speed"
                                android:fontFamily="sans-serif-bold"
                                android:textColor="#0F172A"/>
                            <TextView
                                android:id="@+id/txtSpeedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="1.5x"
                                android:textColor="#4F46E5"
                                android:fontFamily="sans-serif-black"/>
                        </RelativeLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/speedSlider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:valueFrom="1.0"
                            android:valueTo="3.0"
                            app:thumbRadius="10dp"
                            app:thumbColor="#FFFFFF"
                            app:thumbStrokeColor="#4F46E5"
                            app:thumbStrokeWidth="2dp"
                            app:trackHeight="8dp"
                            app:trackColorActive="#4F46E5"
                            app:trackColorInactive="#F1F5F9"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- AKSİYON BUTONU (Premium Gradient Feel) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmCalibration"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="40dp"
                    android:text="SYNC &amp; START"
                    android:textSize="16sp"
                    android:letterSpacing="0.05"
                    app:cornerRadius="24dp"
                    android:backgroundTint="#4F46E5"
                    app:icon="@drawable/ic_arrow_right"
                    app:iconGravity="textEnd"
                    app:iconPadding="12dp"
                    android:fontFamily="sans-serif-black"
                    app:elevation="8dp"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>