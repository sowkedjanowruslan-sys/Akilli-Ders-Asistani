<?xml version="1.0" encoding="utf-8"?>
<!--
    NEUTRAL STUDIO - PLATINUM ARCHITECTURE v7.0
    DESIGN SYSTEM: INDUSTRIAL PRECISION / iOS 18 DYNAMIC

    Refinements:
    - Expanded horizontal breathing room (24dp)
    - High-contrast Slate-Neutral typography
    - Precision alignment for the dynamic timeline node
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardElevation="0dp"
    app:cardCornerRadius="0dp"
    app:cardBackgroundColor="@android:color/transparent"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="22dp"
        android:paddingHorizontal="20dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- LAYER 1: TIME ENGINE (Sol Sütun) -->
        <LinearLayout
            android:id="@+id/layoutTimeEngine"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/txtStartTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:includeFontPadding="false"
                tools:text="19:00" />

            <TextView
                android:id="@+id/txtEndTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.8"
                android:includeFontPadding="false"
                tools:text="20:00" />

            <!-- DİNAMİK KALAN SÜRE: Fokus durumunda yeşil parlar -->
            <TextView
                android:id="@+id/txtRemainingTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#10B981"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.02"
                android:visibility="gone"
                tools:text="15 dk kaldı"
                tools:visibility="visible" />
        </LinearLayout>


        <!-- LAYER 2: NEURAL TIMELINE (Dikey Takip Hattı) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/timelineContainer"
            android:layout_width="24dp"
            android:layout_height="0dp"
            android:layout_marginStart="14dp"
            app:layout_constraintStart_toEndOf="@id/layoutTimeEngine"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Statik Ana Hat -->
            <View
                android:layout_width="1.2dp"
                android:layout_height="match_parent"
                android:background="#E2E8F0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- HAREKETLİ NODE: Kotlin ile verticalBias (0.0 - 1.0) kontrol edilir -->
            <View
                android:id="@+id/vTimelineNode"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/shape_neural_node"
                android:elevation="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.0" />

        </androidx.constraintlayout.widget.ConstraintLayout>


        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@id/actionArea"
            app:layout_constraintStart_toEndOf="@id/timelineContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/txtLessonDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ios_blue"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:includeFontPadding="false"
                tools:text="PAZARTESİ" />

            <TextView
                android:id="@+id/txtLessonName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#0F172A"
                android:textSize="17sp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="-0.01"
                android:lineHeight="20sp"
                tools:text="Yapay Zeka Mimarisi" />

            <TextView
                android:id="@+id/txtDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.8"
                tools:text="Amfi 1 • Dr. Eren" />
        </LinearLayout>

        <!-- LAYER 4: ACTION HUB (Sağ Butonlar) -->
        <LinearLayout
            android:id="@+id/actionArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- DELETE: Soft-Red Glass -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnDeleteLesson"
                android:layout_width="38dp"
                android:layout_height="38dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0DFF3B30"
                app:strokeWidth="1dp"
                app:strokeColor="#1AFF3B30">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="@color/ios_red" />
            </com.google.android.material.card.MaterialCardView>

            <!-- EDIT: Neutral Glass -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnEditLesson"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D0F172A"
                app:strokeWidth="1dp"
                app:strokeColor="#1A0F172A">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="#64748B" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- LAYER 5: DYNAMIC LIVE BADGE -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tagLive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardBackgroundColor="#10B981"
            app:cardCornerRadius="10dp"
            app:cardElevation="6dp"
            app:strokeWidth="1dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="-12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="LIVE"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05" />
        </com.google.android.material.card.MaterialCardView>

        <!-- APPLE STYLE DIVIDER (Metin hizasından başlar) -->
        <View
            android:id="@+id/itemDivider"
            android:layout_width="0dp"
            android:layout_height="0.8dp"
            android:background="#F1F5F9"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/layoutContent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>