<?xml version="1.0" encoding="utf-8"?>
<!--
    AKILLI DERS ASISTANI - USER ROLE SELECTION
    DESIGN SYSTEM: APPLE iOS 18 PLATINUM GLASS
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardCornerRadius="40dp"
    app:cardElevation="24dp"
    app:strokeWidth="1.2dp"
    app:strokeColor="#E5E5EA"
    app:cardBackgroundColor="@color/ios_bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <!-- IOS GRABBER -->
        <View
            android:layout_width="36dp"
            android:layout_height="5dp"
            android:background="#D1D1D6"
            android:layout_marginBottom="20dp"
            android:alpha="0.6" />

        <!-- HEADER SECTION -->
        <TextView
            android:id="@+id/txtDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kimliği Belirleyin"
            android:textColor="@color/ios_text_primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.03" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sizin için en uygun modu seçin"
            android:textColor="@color/ios_text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="32dp" />

        <!-- EĞİTMEN SEÇENEĞİ (Platinum Card Style) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelectTeacher"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/ios_blue"
            app:cardBackgroundColor="#F8F9FF">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:id="@+id/iconTeacher"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_lesson_ios"
                    app:tint="@color/ios_blue" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/iconTeacher"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Eğitmen"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ders yönetimi ve AI analizleri"
                        android:textColor="@color/ios_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_play_arrow"
                    app:tint="@color/ios_blue"
                    android:alpha="0.5"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ÖĞRENCİ SEÇENEĞİ (Platinum Card Style) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelectStudent"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E5EA"
            app:cardBackgroundColor="#FFFFFF">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:id="@+id/iconStudent"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_students_ios"
                    app:tint="#8E8E93" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/iconStudent"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Öğrenci"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Katılım, geri bildirim ve arşiv"
                        android:textColor="@color/ios_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_play_arrow"
                    app:tint="#C7C7CC"
                    android:alpha="0.5"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FOOTER INFO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-medium"
            android:text="modlar arası geçişi sadece bir defa yapabilirsiniz."
            android:textColor="#C7C7CC"

            android:textSize="11sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>