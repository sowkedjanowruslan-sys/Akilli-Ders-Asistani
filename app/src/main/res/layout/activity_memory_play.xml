<?xml version="1.0" encoding="utf-8"?>
<!--    NEURAL MEMORY - CALIBRATION PRO
    DESIGN SYSTEM: NEUTRAL STUDIO / iOS 18 DYNAMIC
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7">

    <!-- LAYER 0: AMBIENT DEPTH (Arka plan derinliği) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:background="@drawable/bg_ios_ambient_glow"
        android:backgroundTint="#1C1C1E"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- LAYER 1: TOP NAVIGATION -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_ios_button_circle"
            android:backgroundTint="#33FFFFFF"
            android:src="@drawable/ic_back_ios"
            app:tint="#FFFFFF"
            android:layout_centerVertical="true"/>

        <ImageButton
            android:id="@+id/btnShowMemoryRankings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_ios_button_circle"
            android:backgroundTint="#33FFFFFF"
            android:src="@android:drawable/btn_star_big_on"
            app:tint="#FFD60A" />
    </RelativeLayout>

    <!-- LAYER 2: HERO BENTO CARD (Merkezi Cam Kart) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/previewCard"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="60dp"
        app:cardElevation="40dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#44FFFFFF"
        app:cardBackgroundColor="#CCFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Arka Plan Süslemesi (Blur efekti hissi için) -->
            <ImageView
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_sync_ios"
                android:alpha="0.05"
                app:tint="#5856D6" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LEVEL"
                    android:textColor="#5856D6"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/txtMemoryUnlockedLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01"
                    android:textSize="82sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#1C1C1E"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.05" />
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- LAYER 3: CONTROLS GROUP (iOS Ayarlar Stili) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="50dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E5E5EA"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/previewCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Neural Calibration"
                android:textSize="22sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="#1C1C1E"
                android:letterSpacing="-0.02"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kart hızı ve zorluk seviyesini belirleyin."
                android:textColor="#8E8E93"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <!-- Seviye Göstergesi -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hız Senkronizasyonu"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#1C1C1E"/>

                <TextView
                    android:id="@+id/txtSpeedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="1.0x"
                    android:textColor="#5856D6"
                    android:fontFamily="sans-serif-black"/>
            </RelativeLayout>

            <!-- Profesyonel Slider -->
            <com.google.android.material.slider.Slider
                android:id="@+id/speedSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:valueFrom="0.5"
                android:valueTo="2.5"
                android:value="1.0"
                app:thumbRadius="12dp"
                app:thumbColor="#FFFFFF"
                app:thumbStrokeWidth="4dp"
                app:thumbStrokeColor="#5856D6"
                app:trackColorActive="#5856D6"
                app:trackColorInactive="#E5E5EA"
                app:trackHeight="8dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- LAYER 4: BOTTOM DOCK AREA -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmMemoryStart"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_centerInParent="true"
            android:text="OTURUMU BAŞLAT"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            app:backgroundTint="#1C1C1E"
            app:cornerRadius="20dp"
            app:elevation="8dp"
            app:icon="@drawable/ic_play_arrow"
            app:iconGravity="textStart"
            app:iconPadding="12dp"/>
    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>