<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="40dp"
    app:cardElevation="30dp"
    app:cardBackgroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@drawable/bg_ios_glass_card">

        <!-- Durum İkonu veya Başlık -->
        <TextView
            android:id="@+id/txtGameOverReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TUR TAMAMLANAMADI"
            android:textColor="#FF3B30"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:textSize="12sp"/>

        <!-- Skor Odak Noktası -->
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/bg_score_circle" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOPLAM PUAN"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#8E8E93"/>

                <TextView
                    android:id="@+id/txtFinalScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="42sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#1C1C1E"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- Detay İstatistikler (Bento Grid Stil) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/txtFinalLevel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Level 05" android:fontFamily="sans-serif-black" android:textColor="#5856D6"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SEVİYE" android:textSize="10sp" android:textColor="#8E8E93"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="30dp" android:background="#F2F2F7"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/txtFinalStreak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:fontFamily="sans-serif-black" android:textColor="#34C759"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STREAK" android:textSize="10sp" android:textColor="#8E8E93"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Aksiyon Butonları -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:text="Tekrar Meydan Oku"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-bold"
            app:cornerRadius="20dp"
            app:backgroundTint="#1C1C1E"
            app:elevation="0dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExit"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Laboratuvardan Ayrıl"
            android:textAllCaps="false"
            android:textColor="#8E8E93"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>