<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBFBFD"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ==========================================================
         LAYER 0: ATMOSPHERIC DEPTH (Ambient Glows)
         ========================================================== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:layout_width="600dp"
            android:layout_height="600dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="-300dp"
            android:layout_marginStart="-250dp"
            android:alpha="0.10"
            android:background="@drawable/bg_neutral_ambient"
            android:backgroundTint="#4F46E5" />

        <View
            android:layout_width="500dp"
            android:layout_height="500dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="-200dp"
            android:layout_marginEnd="-150dp"
            android:alpha="0.08"
            android:background="@drawable/bg_neutral_ambient"
            android:backgroundTint="#10B981" />
    </FrameLayout>

    <!-- ==========================================================
         LAYER 1: NAVIGATION HUB
         ========================================================== -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:contentInsetStart="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_neutral_back_btn"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_back_ios"
                        app:tint="#0F172A" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02"
                    android:text="Ders Yapılandırma"
                    android:textColor="#0F172A"
                    android:textSize="18sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/shape_status_indicator"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ==========================================================
         LAYER 2: MAIN SCROLL FORM
         ========================================================== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="140dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- SECTION 1: CORE IDENTIFICATION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:text="KİMLİK BİLGİLERİ"
                android:textColor="#94A3B8"
                android:textSize="10sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_neutral_input_card"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutDersAdi"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Dersin Tam Adı"
                        app:boxStrokeColor="@drawable/bg_neutral_edittext_stroke"
                        app:startIconDrawable="@android:drawable/ic_menu_edit"
                        app:startIconTint="#64748B">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDersAdi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#0F172A" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutEgitmen"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Eğitmen"
                        app:boxStrokeColor="@drawable/bg_neutral_edittext_stroke"
                        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                        app:startIconTint="#64748B">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEgitmen"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#0F172A" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutSinif"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Sınıf / Salon"
                        app:boxStrokeColor="@drawable/bg_neutral_edittext_stroke"
                        app:startIconDrawable="@android:drawable/ic_dialog_map"
                        app:startIconTint="#64748B">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSinif"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#0F172A" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 2: TEMPORAL CONFIGURATION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:text="ZAMANLAMA VE PLANLAMA"
                android:textColor="#94A3B8"
                android:textSize="10sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_neutral_input_card"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-bold"
                        android:text="Tekrarlanan Gün"
                        android:textColor="#64748B"
                        android:textSize="12sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_neutral_spinner_well"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        <Spinner
                            android:id="@+id/spinnerGun"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:paddingStart="16dp"
                            android:entries="@array/gunler_array" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="16dp"
                            android:src="@drawable/ic_chevron_right"
                            android:rotation="90"
                            app:tint="#64748B" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_neutral_time_cell"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@android:color/transparent">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="BAŞLANGIÇ"
                                    android:textColor="#94A3B8"
                                    android:textSize="9sp" />
                                <EditText
                                    android:id="@+id/etBaslangicSaat"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:background="@android:color/transparent"
                                    android:focusable="false"
                                    android:fontFamily="sans-serif-black"
                                    android:gravity="center"
                                    android:text="09:00"
                                    android:textColor="#4F46E5"
                                    android:textSize="22sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <View android:layout_width="16dp" android:layout_height="match_parent" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_neutral_time_cell"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@android:color/transparent">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="16dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="BİTİŞ"
                                    android:textColor="#94A3B8"
                                    android:textSize="9sp" />
                                <EditText
                                    android:id="@+id/etBitisSaat"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:background="@android:color/transparent"
                                    android:focusable="false"
                                    android:fontFamily="sans-serif-black"
                                    android:gravity="center"
                                    android:text="10:30"
                                    android:textColor="#0F172A"
                                    android:textSize="22sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION 3: SYSTEM INTELLIGENCE BANNER -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_neutral_info_banner"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="#4F46E5" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Yapay Zeka destekli asistan, ders başlamadan 60 dk önce sistemleri kalibre ederek bildirim hazırlar."
                        android:textColor="#4F46E5"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ==========================================================
         LAYER 3: FLOATING ACTION DOCK
         ========================================================== -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="24dp"
        android:background="@drawable/bg_neutral_bottom_dock"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@android:color/transparent">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@null"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_neutral_button_primary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:text="DEĞİŞİKLİKLERİ KAYDET"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:icon="@drawable/ic_play_arrow"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="#FFFFFF" />
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
