<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ANA UYGULAMA TEMASI -->
    <style name="Theme.AkilliDersAsistani" parent="Theme.MaterialComponents.Light.NoActionBar">

        <item name="colorPrimary">#0F172A</item>
        <item name="colorPrimaryVariant">#1E293B</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#10B981</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <item name="colorContainer">#F1F5F9</item>
        <item name="colorOnContainer">#0F172A</item>
        <item name="colorTertiary">#4F46E5</item>
        <item name="colorOnTertiary">#FFFFFF</item>
        <item name="colorSurfaceVariant">#F8FAFC</item>
        <item name="colorOnSurfaceVariant">#64748B</item>



        <item name="android:windowBackground">#F8FAFC</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#0F172A</item>
        <item name="android:textColorPrimary">#0F172A</item>

        <!-- Üst Durum Çubuğu Ayarları -->
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Xiaomi vb. cihazlarda zorunlu karanlık modu engeller -->
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>
    <!-- FAB Butonları için Özel Yuvarlatılmış Köşe Stili -->
    <style name="RoundedCornerFab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="cornerFamily">rounded</item>
        <item name="cornerRadius">24dp</item> <!-- Köşe yuvarlaklığı derecesi -->
    </style>
    <!-- Yuvarlak Resim Stili -->
    <style name="CircleImageFull">
        <item name="cornerRadius">100dp</item>
    </style>

    <!-- Tonal Button Köprüsü -->
    <style name="Widget.MaterialComponents.Button.TonalButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="backgroundTint">#F1F5F9</item>
        <item name="android:textColor">#0F172A</item>
    </style>

    <!-- Bottom Sheet Temaları -->
    <style name="CustomBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="TransparentDialogRes" parent="CustomBottomSheetDialogTheme" />

</resources>