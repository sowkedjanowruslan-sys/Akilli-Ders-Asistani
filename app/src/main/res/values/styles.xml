<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- TYPOGRAPHY: PLATINUM HEADLINES -->
    <style name="ExpandedTitleStyle" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">#0F172A</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">34sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="CollapsedTitleStyle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">#0F172A</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">17sp</item>
    </style>


    <!-- IMAGES & SHAPES -->
    <style name="RoundedImage" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="CircleImage" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">50%</item>
    </style>


    <!-- DIALOG COMPONENTS -->
    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- Eski isimler için yedekleme (Hata önleyici) -->
    <style name="TransparentBottomSheetStyle" parent="CustomBottomSheetStyle" />
    <style name="TransparentElement" parent="CustomBottomSheetStyle" />


    <!-- NEUTRAL HACKER INPUTS -->
    <style name="HackerInputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/hacker_cyan</item>
        <item name="hintTextColor">@color/hacker_cyan</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">4dp</item>
        <item name="boxCornerRadiusTopEnd">4dp</item>
        <item name="boxBackgroundColor">#0D000000</item>
        <item name="startIconTint">@color/hacker_cyan</item>
    </style>


    <!-- PREMIUM BUTTON STYLES -->
    <style name="HackerButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="backgroundTint">#0F172A</item>
    </style>

</resources>