<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- DIŞ PARLAMA (Shadow/Glow) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#205856D6" />
            <size android:width="14dp" android:height="14dp" />
        </shape>
    </item>
    <!-- ANA NOKTA -->
    <item android:top="3dp" android:left="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/ios_blue" />
            <stroke android:width="1.5dp" android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>